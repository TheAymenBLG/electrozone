# Copy to .env.local and fill in. The app runs WITHOUT these (localStorage demo mode).

# Supabase (optional — enables real backend instead of localStorage)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini (optional — enables the real AI assistant; falls back to a rule-based bot if empty)
# For the hackathon this is called client-side for simplicity.
# For production, move it to a Supabase Edge Function so the key isn't exposed.
VITE_GEMINI_API_KEY=
